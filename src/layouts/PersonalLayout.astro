---
import '../styles/global.css';
import AmbientAudio from '../components/personal/AmbientAudio.tsx';
import Portal from '../components/Portal.tsx';
import PortalReveal from '../components/PortalReveal.tsx';

interface Props {
  title?: string;
}
const { title = 'The Archive — nannomnom' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Geist:wght@300..700&family=Geist+Mono:wght@300..700&family=Caveat:wght@400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="archive-body">
    <!-- Paper grain overlay -->
    <div class="grain-overlay" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="200%" height="200%">
        <filter id="paper-grain">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch" />
          <feColorMatrix type="saturate" values="0" />
        </filter>
        <rect width="100%" height="100%" filter="url(#paper-grain)" opacity="0.05" />
      </svg>
    </div>

    <header class="archive-header" role="banner">
      <span class="header-label">ARCHIVE №001</span>

      <a href="/shishin" class="header-title" aria-label="The Archive home">
        nannomnom
      </a>

      <div class="header-actions">
        <AmbientAudio client:load />
        <button
          class="wax-exit"
          onclick="window.dispatchEvent(new CustomEvent('portal:return'))"
          aria-label="Return to main site"
        >
          EXIT
        </button>
      </div>
    </header>

    <main class="archive-main">
      <slot />
    </main>

    <Portal client:load />
    <PortalReveal client:load />
  </body>
</html>

<style>
  .archive-body {
    min-height: 100vh;
    background-color: var(--arch-parchment);
    color: var(--arch-ink);
    font-family: var(--font-archive-display);
    position: relative;
    overflow-x: hidden;
  }

  html[data-theme="dark"] .archive-body {
    background-color: var(--arch-navy);
    color: var(--arch-parchment);
  }

  .grain-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* ── Header ── */
  .archive-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 32px;
    background-color: var(--arch-parchment);
    border-bottom: 1px solid color-mix(in srgb, var(--arch-gold) 40%, transparent);
    backdrop-filter: blur(4px);
  }

  html[data-theme="dark"] .archive-header {
    background-color: var(--arch-navy);
  }

  .header-label {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--arch-stone);
    flex: 1;
  }

  .header-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 600;
    font-style: italic;
    color: var(--arch-ink);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  html[data-theme="dark"] .header-title {
    color: var(--arch-parchment);
  }

  .header-title:hover { color: var(--arch-gold); }

  .header-title:focus-visible {
    outline: 2px solid var(--arch-gold);
    outline-offset: 3px;
  }

  .header-actions {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
  }

  /* Wax-seal exit button */
  .wax-exit {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--arch-oxblood);
    color: var(--arch-parchment);
    border: none;
    cursor: pointer;
    font-family: 'Geist Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  .wax-exit:hover {
    background-color: color-mix(in srgb, var(--arch-oxblood) 80%, black);
    transform: scale(1.05);
  }

  .wax-exit:focus-visible {
    outline: 2px solid var(--arch-gold);
    outline-offset: 3px;
  }

  /* ── Main ── */
  .archive-main {
    position: relative;
    z-index: 1;
    padding-top: 69px; /* header height */
  }

  @media (max-width: 767px) {
    .archive-header { padding: 10px 16px; }
    .header-label { font-size: 9px; }
  }
</style>
