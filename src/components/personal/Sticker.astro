---
interface Props {
  src: string;
  rotate?: number;
  scale?: number;
  x: string;
  y: string;
  alt?: string;
}
const { src, rotate = 0, scale = 1, x, y, alt = '' } = Astro.props;
const id = `sticker-${Math.random().toString(36).slice(2, 7)}`;
---

<div
  class="sticker"
  id={id}
  style={`
    position: absolute;
    left: ${x};
    top: ${y};
    transform: rotate(${rotate}deg) scale(${scale});
    transform-origin: center;
    pointer-events: auto;
    z-index: 20;
    will-change: transform;
  `}
  aria-hidden={alt ? undefined : 'true'}
>
  <img src={src} alt={alt} width="64" height="64" loading="lazy" />
</div>

<style>
  .sticker {
    transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: default;
    display: inline-block;
  }

  .sticker:hover {
    /* wobble: override inline transform with a combined one via CSS var trick */
    animation: sticker-wobble 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes sticker-wobble {
    0%   { transform: v-rotate scale(v-scale) rotate(0deg); }
    30%  { transform: v-rotate scale(v-scale) rotate(5deg); }
    60%  { transform: v-rotate scale(v-scale) rotate(-4deg); }
    80%  { transform: v-rotate scale(v-scale) rotate(2deg); }
    100% { transform: v-rotate scale(v-scale) rotate(0deg); }
  }
</style>

<script define:vars={{ id, rotate, scale }}>
  const el = document.getElementById(id);
  if (el) {
    el.addEventListener('mouseenter', () => {
      el.style.transition = 'none';
      let startTime = null;
      const keyframes = [0, 5, -4, 2, 0];
      const times = [0, 120, 240, 340, 420];
      function animate(ts) {
        if (!startTime) startTime = ts;
        const elapsed = ts - startTime;
        let angle = rotate;
        for (let i = 0; i < times.length - 1; i++) {
          if (elapsed >= times[i] && elapsed < times[i + 1]) {
            const t = (elapsed - times[i]) / (times[i + 1] - times[i]);
            angle = rotate + keyframes[i] + (keyframes[i + 1] - keyframes[i]) * t;
            break;
          }
        }
        if (elapsed >= times[times.length - 1]) angle = rotate;
        el.style.transform = `rotate(${angle}deg) scale(${scale})`;
        if (elapsed < times[times.length - 1]) requestAnimationFrame(animate);
        else el.style.transform = `rotate(${rotate}deg) scale(${scale})`;
      }
      requestAnimationFrame(animate);
    });
  }
</script>
