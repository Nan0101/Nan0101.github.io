---
import ProLayout from '../layouts/ProLayout.astro';
import resumeData from '../content/resume.json';

const { summary, experience, education, skills, certifications } = resumeData;
---

<ProLayout title="Résumé — nannomnom">
  <div class="resume-wrap">
    <header class="resume-header">
      <div>
        <h1 class="resume-name">Nandini Soni</h1>
        <p class="resume-tagline">Software Engineer · AI/ML · Buffalo, NY</p>
      </div>
      <a href="/resume.pdf" class="download-btn" download aria-label="Download résumé PDF">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Download PDF
      </a>
    </header>

    <hr class="divider" />

    <section class="resume-section">
      <h2 class="section-label">Summary</h2>
      <p class="summary-text">{summary}</p>
    </section>

    <hr class="divider" />

    <section class="resume-section">
      <h2 class="section-label">Experience</h2>
      <div class="entries">
        {experience.map(job => (
          <div class="entry">
            <div class="entry-meta">
              <div class="entry-left">
                <span class="entry-title">{job.role}</span>
                <span class="entry-org">{job.company}</span>
              </div>
              <div class="entry-right">
                <span class="entry-dates">{job.dates}</span>
                <span class="entry-location">{job.location}</span>
              </div>
            </div>
            <ul class="bullet-list">
              {job.bullets.map(b => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <hr class="divider" />

    <section class="resume-section">
      <h2 class="section-label">Education</h2>
      <div class="entries">
        {education.map(edu => (
          <div class="entry">
            <div class="entry-meta">
              <div class="entry-left">
                <span class="entry-title">{edu.degree}</span>
                <span class="entry-org">{edu.school}</span>
              </div>
              <div class="entry-right">
                <span class="entry-dates">{edu.dates}</span>
              </div>
            </div>
            {edu.notes && <p class="entry-notes">{edu.notes}</p>}
          </div>
        ))}
      </div>
    </section>

    <hr class="divider" />

    <section class="resume-section">
      <h2 class="section-label">Skills</h2>
      <div class="skills-grid">
        {Object.entries(skills).map(([group, items]) => (
          <div class="skill-group">
            <span class="skill-group-label">{group}</span>
            <div class="skill-chips">
              {(items as string[]).map(s => <span class="chip">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr class="divider" />

    <section class="resume-section">
      <h2 class="section-label">Certifications</h2>
      <div class="entries">
        {certifications.map(cert => (
          <div class="cert-row">
            <span class="cert-name">{cert.name}</span>
            <span class="cert-meta">{cert.issuer} · {cert.year}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</ProLayout>

<style>
  .resume-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-10);
  }

  .resume-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .resume-name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-1);
  }

  .resume-tagline {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--nebula-violet);
    margin: 0;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-decoration: none;
    color: var(--fg);
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s;
    position: sticky;
    top: 72px;
    align-self: flex-start;
  }

  .download-btn:hover {
    border-color: var(--nebula-violet);
    color: var(--nebula-violet);
  }

  .download-btn:focus-visible {
    outline: 2px solid var(--nebula-violet);
    outline-offset: 3px;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--line);
    margin: var(--space-6) 0;
  }

  .resume-section { }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--nebula-violet);
    margin: 0 0 var(--space-5);
  }

  .summary-text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.85;
    margin: 0;
  }

  .entries {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .entry-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .entry-left, .entry-right {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .entry-right {
    align-items: flex-end;
    text-align: right;
  }

  .entry-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .entry-org {
    font-family: var(--font-body);
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .entry-dates {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    opacity: 0.55;
  }

  .entry-location {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    opacity: 0.4;
  }

  .bullet-list {
    margin: 0;
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .bullet-list li {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  .entry-notes {
    font-family: var(--font-body);
    font-size: 0.88rem;
    line-height: 1.6;
    opacity: 0.6;
    margin: var(--space-2) 0 0;
    font-style: italic;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .skill-group {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }

  .skill-group-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 2px;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 2px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    opacity: 0.8;
    line-height: 1.6;
  }

  .cert-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--line);
  }

  .cert-row:last-child { border-bottom: none; }

  .cert-name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .cert-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    opacity: 0.5;
    white-space: nowrap;
  }

  a:hover { color: var(--nebula-violet); }

  @media (max-width: 600px) {
    .resume-wrap { padding: var(--space-6) var(--space-5) var(--space-8); }
    .skill-group { grid-template-columns: 1fr; }
    .skill-group-label { padding-top: 0; }
    .entry-right { align-items: flex-start; text-align: left; }
    .download-btn { position: static; }
  }

  @media print {
    :global(nav), :global(footer), :global(.cat-btn), .download-btn {
      display: none !important;
    }
    :global(body) {
      background: white !important;
      color: black !important;
    }
    .resume-wrap {
      max-width: 100%;
      padding: 0;
    }
    .chip {
      border-color: #ccc;
    }
    .divider {
      border-color: #ddd;
    }
  }
</style>
