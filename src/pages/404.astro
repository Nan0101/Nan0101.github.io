---
import ProLayout from '../layouts/ProLayout.astro';
---

<ProLayout title="404 — nannomnom">
  <div class="not-found">
    <span class="four-o-four" aria-hidden="true">404</span>
    <h1 class="headline">this page slipped away</h1>
    <p class="subline">Whatever you were looking for isn't here — it may have moved or never existed.</p>
    <a href="/" class="home-link">← take me home</a>
    <p class="hint">
      Or try a different door —&nbsp;<span class="hint-cat">or find the cat.</span>
    </p>
  </div>
</ProLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 120px);
    padding: var(--space-8) var(--space-6);
    gap: var(--space-4);
  }

  .four-o-four {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 14rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.85;
    color: var(--nebula-violet);
    opacity: 0.12;
    user-select: none;
    display: block;
    margin-bottom: var(--space-2);
  }

  .headline {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .subline {
    font-family: var(--font-body);
    font-size: 1rem;
    opacity: 0.55;
    max-width: 38ch;
    line-height: 1.65;
    margin: 0;
  }

  .home-link {
    display: inline-block;
    margin-top: var(--space-2);
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--line);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--fg);
    transition: border-color 0.15s, color 0.15s;
  }

  .home-link:hover {
    border-color: var(--nebula-violet);
    color: var(--nebula-violet);
  }

  .home-link:focus-visible {
    outline: 2px solid var(--nebula-violet);
    outline-offset: 3px;
  }

  .hint {
    font-family: var(--font-body);
    font-size: 0.85rem;
    opacity: 0.35;
    margin: var(--space-2) 0 0;
  }

  .hint-cat {
    font-style: italic;
  }
</style>
